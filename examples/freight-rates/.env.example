DEEPSEEK_API_KEY=
FREIGHTPULSE_API_KEY=

# Azure Bot Framework credentials
MICROSOFT_APP_ID=       # Azure Bot app ID (Azure Portal → Bot registration → Configuration)
MICROSOFT_APP_PASSWORD= # Azure Bot client secret

# App Tenant ID (needed for Single Tenant bot)
MICROSOFT_APP_TENANT_ID= # Azure Tenant ID

# Microsoft Graph — email tool
# UPN or email address of the mailbox to read (e.g. you@yourcompany.com)
# Requires Mail.Read + Mail.ReadBasic + User.Read.All application permissions with admin consent
GRAPH_USER_EMAIL=
